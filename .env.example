# =============================================================================
# VAIBHAV GROWTH ENGINE — Environment Variables
# Author: Vaibhav Sonava | github.com/Vaibhavsonava2005
# =============================================================================
# Copy this file to .env and fill in your API keys.
# NEVER commit .env to git (it is in .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# LEAD DISCOVERY
# -----------------------------------------------------------------------------

# Apollo.io — Lead Discovery & Company Search
# Get key at: https://app.apollo.io/#/settings/integrations/api
# Free tier: unlimited org searches (no credits), people search limited
# Required: No (Hunter fills this gap)
APOLLO_API_KEY=

# Hunter.io — Email Discovery & Verification
# Get key at: https://hunter.io/api-keys
# Free tier: 25 domain searches/month, 50 email finders/month
# Required: YES (primary contact discovery source)
HUNTER_API_KEY=your_hunter_api_key_here

# Prospeo — Contact Enrichment
# Get key at: https://prospeo.io/dashboard/api
# Free tier: 100 credits/month
# Required: Recommended (enhances Hunter contacts)
PROSPEO_API_KEY=your_prospeo_api_key_here

# -----------------------------------------------------------------------------
# EMAIL DELIVERY
# -----------------------------------------------------------------------------

# Brevo (formerly Sendinblue) — Transactional Email
# Get key at: https://app.brevo.com/settings/keys/api
# Free tier: 300 emails/day, unlimited contacts
# Required: YES (email sending)
BREVO_API_KEY=your_brevo_api_key_here

# Your sender email (must be verified in Brevo)
SENDER_EMAIL=vaibhav@deknek.com
SENDER_NAME=Vaibhav Sonava

# -----------------------------------------------------------------------------
# AI PROVIDERS (Email Personalization)
# -----------------------------------------------------------------------------

# Gemini — Google AI
# Get key at: https://aistudio.google.com/app/apikey
# Free tier available
GEMINI_API_KEY=

# Groq — Ultra-fast LLM inference (llama-3.1-8b-instant)
# Get key at: https://console.groq.com/keys
# Free tier: generous rate limits
# Required: Recommended
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter — Multi-model AI routing (gemma-4-31b)
# Get key at: https://openrouter.ai/keys
# Free tier available for many models
# Required: Recommended
OPENROUTER_API_KEY=your_openrouter_api_key_here

# -----------------------------------------------------------------------------
# PIPELINE CONFIGURATION
# -----------------------------------------------------------------------------

# Maximum companies to discover per domain run
MAX_COMPANIES=10

# Maximum contacts to find per company
MAX_CONTACTS_PER_COMPANY=3

# Maximum API retry attempts on failure
MAX_RETRIES=3

# HTTP request timeout in seconds
REQUEST_TIMEOUT=30

# Set to True to never send real emails (safe testing mode)
DRY_RUN=False

# Logging verbosity: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
